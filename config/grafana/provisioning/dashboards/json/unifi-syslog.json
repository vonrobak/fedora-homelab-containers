      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum(count_over_time({job=\"unifi-syslog\", priority=~\"warning|err|crit|alert|emerg\"}[1h]))",
          "refId": "A"
        }
      ],
      "title": "Warning+ Events (1h)",
      "type": "stat"
    },
    {
